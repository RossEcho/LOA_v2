{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LOA Tool Result",
  "type": "object",
  "required": [
    "ok",
    "exit_code",
    "stdout",
    "stderr",
    "duration_ms",
    "artifacts"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer"
    },
    "stdout": {
      "type": "string"
    },
    "stderr": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
