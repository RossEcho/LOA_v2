{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LOA Tool Call",
  "type": "object",
  "required": [
    "tool_name",
    "args",
    "cwd",
    "timeout_seconds",
    "action_class",
    "env"
  ],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "args": {
      "type": "object"
    },
    "cwd": {
      "type": [
        "string",
        "null"
      ]
    },
    "timeout_seconds": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "action_class": {
      "type": "string",
      "enum": [
        "READ",
        "WRITE",
        "NETWORK",
        "SYSTEM"
      ]
    },
    "env": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
