{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LOA Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "session_name", "steps", "final_output"],
  "properties": {
    "plan_id": {"type": "string", "minLength": 1},
    "session_name": {"type": "string", "minLength": 1, "maxLength": 80},
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "tool", "args"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "tool": {"type": "string", "minLength": 1},
          "args": {"type": "object"},
          "timeout_sec": {"type": "integer", "minimum": 1, "maximum": 3600},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "success_criteria": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {"type": "string", "enum": ["exit_code"]},
              "equals": {"type": "integer"},
              "stdout_contains": {
                "type": "array",
                "items": {"type": "string"}
              },
              "stderr_contains": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "retry_policy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "max_retries": {"type": "integer", "minimum": 0, "maximum": 10}
            }
          }
        }
      }
    },
    "final_output": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  }
}
